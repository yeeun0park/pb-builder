# /api/gemini-html 서버 함수에서 사용 (필수)
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Rate limit (선택) — 두 값을 모두 설정하면 IP당 분 5회·일 50회 강제
# Upstash 무료 가입: https://console.upstash.com/ → Redis → "Create database"
# 두 값은 Database 페이지의 "REST API" 섹션에서 복사
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
